# ─────────────────────────────────────────────────────────────
# Hardened sshd_config for a single-admin homelab host.
# Validate before reload:  sshd -t -f /etc/ssh/sshd_config
# ─────────────────────────────────────────────────────────────

# Non-default port — defense-in-depth against opportunistic internet scans.
# Doesn't replace key-only auth + fail2ban, just trims the noise floor in logs.
# Remember to allow it through UFW:  sudo ufw allow 2222/tcp
Port 2222
AddressFamily inet
Protocol 2

# Auth — keys only
PermitRootLogin no
PasswordAuthentication no
ChallengeResponseAuthentication no
KbdInteractiveAuthentication no
UsePAM yes
PubkeyAuthentication yes
AuthenticationMethods publickey

# Limit who can log in
AllowUsers admin

# Strong crypto only
KexAlgorithms curve25519-sha256,curve25519-sha256@libssh.org,sntrup761x25519-sha512@openssh.com
Ciphers chacha20-poly1305@openssh.com,aes256-gcm@openssh.com,aes128-gcm@openssh.com
MACs hmac-sha2-512-etm@openssh.com,hmac-sha2-256-etm@openssh.com

# Session hygiene
ClientAliveInterval 300
ClientAliveCountMax 2
LoginGraceTime 30
MaxAuthTries 3
MaxSessions 4

# No nonsense
X11Forwarding no
AllowAgentForwarding no
AllowTcpForwarding no
PermitTunnel no
GatewayPorts no
PrintMotd no
PermitUserEnvironment no

# Logging
LogLevel VERBOSE
SyslogFacility AUTH

Subsystem sftp /usr/lib/openssh/sftp-server
