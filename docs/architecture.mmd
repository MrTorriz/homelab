flowchart TB
    classDef perimeter fill:#1c1c1c,stroke:#f0a830,stroke-width:1.5px,color:#e6e6e6
    classDef detect    fill:#1c1c1c,stroke:#e06c75,stroke-width:1.5px,color:#e6e6e6
    classDef proxy     fill:#1c1c1c,stroke:#5fa8d3,stroke-width:1.5px,color:#e6e6e6
    classDef apps      fill:#161616,stroke:#a3be8c,stroke-width:1.2px,color:#e6e6e6
    classDef obs       fill:#161616,stroke:#56b6c2,stroke-width:1.2px,color:#e6e6e6
    classDef vpn       fill:#1c1c1c,stroke:#c678dd,stroke-width:1.5px,color:#e6e6e6
    classDef ext       fill:#0d0d0d,stroke:#5c6370,stroke-width:1px,color:#a3a3a3,stroke-dasharray:3 3

    Internet([Internet]):::ext

    subgraph EDGE["🌐 Edge"]
        direction TB
        CF["Cloudflare Tunnel<br/>+ Google OAuth"]:::perimeter
        Router["Router / Gateway<br/>(no port-forwarding)"]:::perimeter
    end

    subgraph LAN["🏠 Home LAN — 192.168.x.0/24"]
        direction TB
        AdGuard["AdGuard Home<br/>DNS · ad-blocking"]:::perimeter

        subgraph HOST["🖥️ Docker Host — Ubuntu 24.04"]
            direction TB

            subgraph PROXY["Reverse proxy"]
                NPM["Nginx Proxy Manager<br/>:80 / :443"]:::proxy
            end

            subgraph DETECT["Detection layer"]
                direction LR
                UFW["UFW<br/>default-deny"]:::detect
                F2B["fail2ban<br/>SSH brute-force"]:::detect
                Suri["Suricata IDS<br/>passive monitoring"]:::detect
            end

            subgraph APPS["Apps"]
                direction LR
                Media["Media · *ARR<br/>Plex · Sonarr · Radarr<br/>Lidarr · Bazarr · Tdarr"]:::apps
                Photos["Photos<br/>Immich (NVENC + CUDA)"]:::apps
                Files["Files & sync<br/>Nextcloud"]:::apps
                AI["Local AI<br/>Ollama · Open WebUI<br/>Faster-Whisper"]:::apps
            end

            subgraph OBS["Observability"]
                direction LR
                Glances["Glances · Scrutiny<br/>Speedtest · ntfy"]:::obs
                Alerts["Event-driven<br/>SSH · sudo · fail2ban<br/>Suricata · Docker"]:::obs
            end

            VPN(["Mullvad WG<br/>lockdown mode"]):::vpn
            QB["qBittorrent<br/>VPN-bound · killswitch"]:::vpn
        end
    end

    Internet ==>|"HTTPS"| CF
    Internet -.->|"DNS / WAN"| Router
    CF ==>|"private tunnel"| NPM
    Router --> AdGuard
    AdGuard --> NPM
    NPM ==> APPS
    NPM --> OBS
    UFW -.->|"drops 22k/wk"| Internet
    F2B -.->|"bans"| NPM
    Suri -.->|"signature alerts"| Alerts
    QB ==>|"only via"| VPN
    VPN ==>|"exit IP"| Internet
