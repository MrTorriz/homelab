# ────────────────────────────────────────────────────────────
# Homelab — example environment file
# Copy to `.env` and fill in real values. Never commit `.env`.
# ────────────────────────────────────────────────────────────

# ── Host & network ──
LAN_IP=192.168.1.10
DOMAIN=example.com
TZ=Europe/Stockholm
PUID=1000
PGID=1000

# ── Storage paths (host) ──
APPDATA_DIR=/srv/appdata
MEDIA_DIR=/mnt/media
STORAGE_DIR=/mnt/storage

# ── Speedtest Tracker ──
SPEEDTEST_APP_KEY=base64:generate-with-php-artisan-key-generate

# ── Immich (photos) ──
IMMICH_VERSION=release
DB_PASSWORD=change-me
DB_USERNAME=postgres
DB_DATABASE_NAME=immich

# ── Nextcloud (files & sync) ──
NEXTCLOUD_DOMAIN=cloud.example.com
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASS=change-me
NEXTCLOUD_DB_PASS=change-me
NEXTCLOUD_REDIS_PASS=change-me

# ── Local LLM stack ──
# Generate with: openssl rand -hex 32
WEBUI_SECRET_KEY=change-me

# ── Miniflux (RSS) ──
MINIFLUX_DB_PASS=change-me
MINIFLUX_ADMIN_PASS=change-me

# ── Cloudflare Tunnel ──
CLOUDFLARE_TUNNEL_TOKEN=

# ── ntfy (notifications) ──
NTFY_TOPIC=homelab-alerts
# Optional Bearer token if your ntfy instance requires auth (see scripts/lib.sh)
NTFY_TOKEN=

# ── Observability (Prometheus + Grafana) ──
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me
GRAFANA_DOMAIN=grafana.example.com
PROMETHEUS_RETENTION=90d
